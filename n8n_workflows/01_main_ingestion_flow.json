      "id": "dba23774-9532-4133-8355-dc564f3924d0",
      "name": "CODE FOR CHUNKING-EMPLOYEE(markdown)"
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto'); // <--- THIS LINE IS MANDATORY\n\n// 1. Get all input items\nconst items = $input.all();\nconst results = [];\n\n// 2. Loop through each item (We use a loop to handle the async helper)\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i];\n  const binaryKey = 'data'; \n  //const binaryKey = 'fake_key_to_force_error';\n\n  try {\n    // Pull the real file from disk\n    const fileBuffer = await this.helpers.getBinaryDataBuffer(i, binaryKey);\n    \n    // 3. Generate the Content Hash\n    const hash = crypto.createHash('sha256').update(fileBuffer).digest('hex');\n\n    // 4. Generate the UUID for the Audit Log based on the filename\n    const nameHash = crypto.createHash('md5').update(item.json.fileName || \"\").digest('hex');\n    const fileUuid = `${nameHash.slice(0,8)}-${nameHash.slice(8,12)}-4${nameHash.slice(13,16)}-a${nameHash.slice(17,20)}-${nameHash.slice(20,32)}`;\n\n    results.push({\n      json: {\n        ...item.json,\n        file_hash: hash,\n        file_uuid: fileUuid,\n        file_size: fileBuffer.length \n      },\n      binary: item.binary\n    });\n    \n  } catch (error) {\n    results.push({\n      json: {\n        ...item.json,\n        error: \"Binary data not found or unreadable\",\n        file_hash: \"ERROR_\" + i,\n        file_uuid: \"ERROR_\" + i\n      },\n      binary: item.binary\n    });\n  }\n}\n\nreturn results;"
      },
      "id": "7ac72a93-5a2d-466d-942b-5a4f424e1ec1",
      "name": "HASH GENERATOR",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -5984,
        2064
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst hashArray = items.map(item => item.json.file_hash);\nconst nameArray = items.map(item => item.json.fileName); // <-- ADDED THIS\n\nreturn {\n  json: {\n    hash_array: hashArray.length > 0 ? hashArray : [\"0\"],\n    name_array: nameArray.length > 0 ? nameArray : [\"0\"] // <-- ADDED THIS\n  }\n};"
      },
