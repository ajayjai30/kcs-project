    {
      "parameters": {
        "jsCode": "const items = $('MOVE BINARY DATA').all();\n\nfor (let i = 0; i < items.length; i++) {\n    // 1. Get the base64 string we saved earlier\n    const base64Data = items[i].json.data;\n    \n    // 2. Rebuild the binary file manually (safely!)\n    items[i].binary = {\n        data: {\n            data: base64Data,\n            mimeType: items[i].json.fileExtension === 'pdf' ? 'application/pdf' : 'text/markdown',\n            fileName: items[i].json.fileName\n        }\n    };\n    \n    // 3. Clean up the JSON by removing the giant text string\n    delete items[i].json.data;\n}\n\n// Return the perfect JSON alongside the newly rebuilt file\nreturn items;"
      },
