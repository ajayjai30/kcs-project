    {
      "parameters": {
        "jsCode": "const allChunks = [];\nconst chunkSize = 1000;\nconst overlap = 200; // <--- ADD THIS: The number of characters to overlap\n\n// Just get the data currently inside this node\nconst items = $input.all();\n\nfor (let i = 0; i < items.length; i++) {\n    const text = items[i].json.text;\n    \n    // Grab the Hash and FileName directly from the current item\n    const fileHash = items[i].json.file_hash;\n    const fileName = items[i].json.fileName;\n\n    if (!text) continue;\n    \n    // THE MAGIC MATH: Advance the loop by (1000 - 200) = 800 characters each time\n    const step = chunkSize - overlap; \n    \n    for (let j = 0; j < text.length; j += step) {\n        allChunks.push({\n            json: {\n                text: text.substring(j, j + chunkSize),\n                file_hash: fileHash,\n                fileName: fileName  // Stamped perfectly onto every chunk\n            },\n            pairedItem: { item: i } \n        });\n    }\n}\n\nreturn allChunks;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3104,
