      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const newFiles = $('HASH GENERATOR').all();\nconst qdrantResponse = $input.all()[0]?.json?.result?.points || [];\n\nreturn newFiles.map(file => {\n  const newHash = file.json.file_hash;\n  const fileName = file.json.fileName;\n  \n  const existingContent = qdrantResponse.find(p => p.payload.file_hash === newHash);\n  const existingName = qdrantResponse.find(p => p.payload.file_name === fileName);\n\n  let action = \"INSERT\";      \n  let targetHash = \"NEW_FILE\";      \n\n  if (existingContent) {\n      action = \"IGNORE\";\n  } else if (existingName) {\n      action = \"UPDATE\"; \n      targetHash = existingName.payload.file_hash;\n  }\n\n  if (file.json.error) action = \"ERROR\";\n\n  return { json: { ...file.json, action, target_hash: targetHash }, binary: file.binary };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
